# ─── News source ──────────────────────────────────────────────────────────
# Get a free key at https://newsapi.org (100 requests/day on free tier)
NEWSAPI_KEY=your_newsapi_key_here
NEWS_COUNTRY=id            # id = Indonesia, us, gb, etc.
NEWS_CATEGORY=general      # general, business, technology, sports, entertainment, health, science

# ─── Claude API (for caption generation) ──────────────────────────────────
# Get key at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_key_here

# ─── Google Custom Search (for images) ────────────────────────────────────
# 1. Create a Programmable Search Engine: https://programmablesearchengine.google.com
#    → enable "Image search" and "Search the entire web"
# 2. Get API key: https://developers.google.com/custom-search/v1/introduction
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_CSE_ID=your_search_engine_id_here
# Filter to Creative Commons licensed images (RECOMMENDED, safer for copyright).
# Set to "any" to disable filter (you accept copyright risk yourself).
IMAGE_LICENSE_FILTER=cc_publicdomain,cc_attribute,cc_sharealike

# ─── Instagram Graph API ──────────────────────────────────────────────────
# Setup guide: see README.md "Instagram setup" section
# You need a Business/Creator account linked to a Facebook Page,
# then a Long-Lived Access Token (60 days, must refresh).
IG_USER_ID=your_instagram_business_account_id
IG_ACCESS_TOKEN=your_long_lived_access_token

# ─── Image hosting (Instagram requires a public URL) ──────────────────────
# Easiest: use imgbb.com free API. Get key at https://api.imgbb.com
IMGBB_API_KEY=your_imgbb_key_here

# ─── Behavior ─────────────────────────────────────────────────────────────
# Set to "true" to skip the actual Instagram upload (for testing)
DRY_RUN=false
